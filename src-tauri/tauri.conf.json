{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevPet",
  "version": "1.0.0",
  "identifier": "com.devpet.app",
  "build": {
    "beforeDevCommand": "npx live-server src --port=1425 --no-browser --quiet",
    "devUrl": "http://localhost:1425",
    "beforeBuildCommand": "",
    "frontendDist": "../src"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "DevPet",
        "label": "main",
        "width": 200,
        "height": 280,
        "minWidth": 150,
        "minHeight": 200,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "visible": false,
        "center": false
      },
      {
        "title": "DevPet Speech",
        "label": "speech",
        "url": "speech.html",
        "width": 200,
        "height": 100,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "visible": false,
        "center": false
      },
      {
        "title": "DevPet Notifications",
        "label": "toast",
        "url": "toast.html",
        "width": 350,
        "height": 250,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "visible": false,
        "center": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": ""
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/okottorika/DevPet/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJEMkUwMERFNEVFQ0Q5OTQKUldTVTJleE8zZ0F1dlcrSWdkLzhpNGlQNTd1K1ZiOEZYa3JEZHYyem5maU9VYXFRTG5vQjcxL0YK"
    }
  }
}
